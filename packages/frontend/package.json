{
  "name": "@grafica/frontend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run --reporter=verbose",
    "test:unit:watch": "vitest --reporter=verbose",
    "test:e2e": "playwright test",
    "lint": "eslint src/ electron/",
    "electron:compile": "tsc --project tsconfig.electron.json",
    "electron:watch": "tsc --project tsconfig.electron.json --watch",
    "electron:dev": "npm run electron:compile && cross-env NODE_ENV=development electron .",
    "electron:build": "npm run electron:compile && electron-builder"
  },
  "dependencies": {
    "@grafica/shared": "workspace:*",
    "chart.js": "^4.5.1",
    "pdf-to-printer": "^5.8.0",
    "pdfjs-dist": "^4.0.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.45.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.19.17",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.0",
    "cross-env": "^10.1.0",
    "electron": "^31.0.0",
    "electron-builder": "^24.13.0",
    "electron-reloader": "^1.2.3",
    "jsdom": "^29.1.0",
    "typescript": "^5.5.0",
    "vite": "^5.3.0",
    "vitest": "^2.0.0",
    "vitest-axe": "^0.1.0"
  }
}
