// Gráfica Manager — Prisma Schema
// Banco: MySQL 8+
// IDs: UUID (sem auto-increment em entidades de domínio — CLAUDE.md seção 9)
// Tokens de e-commerce gravados encriptados — ADR 0001

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  RECEIVED
  IN_PRODUCTION
  PRODUCTION_DONE
  PACKAGED
  SHIPPED
  DELIVERED
}

enum PrintQuality {
  DRAFT
  NORMAL
  HIGH
}

enum ColorProfile {
  CMYK
  RGB
  GRAYSCALE
}

enum StoreSource {
  SHOPEE
  MERCADO_LIVRE
  MANUAL
}

// ─── Entidades ────────────────────────────────────────────────────────────────

model Printer {
  id        String   @id @default(uuid())
  name      String
  model     String?
  // Identificador da impressora no sistema operacional
  systemId  String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  printJobs PrintJob[]

  @@map("printers")
}

model PrintPreset {
  id           String       @id @default(uuid())
  name         String
  description  String?      @db.Text
  quality      PrintQuality
  colorProfile ColorProfile
  paperType    String
  // Gramatura em g/m²
  paperWeight  Int
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  printJobs PrintJob[]

  @@map("print_presets")
}

model Store {
  id             String      @id @default(uuid())
  name           String
  source         StoreSource
  // Valores gravados encriptados via AES-256-GCM (ADR 0001)
  accessToken    String      @db.Text
  refreshToken   String?     @db.Text
  externalShopId String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customers Customer[]
  orders    Order[]

  @@map("stores")
}

model Customer {
  id         String    @id @default(uuid())
  name       String
  email      String?
  phone      String?
  // ID do cliente na plataforma de e-commerce de origem
  externalId String?
  storeId    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  // Soft-delete — queries de listagem filtram deletedAt: null (spec 0001 RNF3)
  deletedAt  DateTime?

  store  Store?  @relation(fields: [storeId], references: [id])
  orders Order[]

  @@index([externalId])
  @@index([storeId])
  @@map("customers")
}

model Order {
  id              String      @id @default(uuid())
  status          OrderStatus @default(RECEIVED)
  // ID do pedido na plataforma de e-commerce de origem
  externalOrderId String?
  notes           String?     @db.Text
  customerId      String?
  storeId         String?
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt
  // Soft-delete — queries de listagem filtram deletedAt: null (spec 0001 RNF3)
  deletedAt       DateTime?

  customer  Customer?   @relation(fields: [customerId], references: [id])
  store     Store?      @relation(fields: [storeId], references: [id])
  printJobs PrintJob[]
  files     OrderFile[]

  @@index([status])
  @@index([customerId])
  @@index([storeId])
  @@index([externalOrderId])
  @@map("orders")
}

model PrintJob {
  id                 String       @id @default(uuid())
  orderId            String?
  printerId          String
  presetId           String?
  quality            PrintQuality
  colorProfile       ColorProfile
  paperType          String
  // Gramatura em g/m²
  paperWeight        Int
  pagesBlackAndWhite Int          @default(0)
  pagesColor         Int          @default(0)
  // Custo estimado do job completo em reais
  estimatedCost      Decimal      @db.Decimal(12, 4)
  printedAt          DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  order   Order?       @relation(fields: [orderId], references: [id])
  printer Printer      @relation(fields: [printerId], references: [id])
  preset  PrintPreset? @relation(fields: [presetId], references: [id])

  @@index([printerId])
  @@index([orderId])
  @@map("print_jobs")
}

// Módulo de Arquivo (Fase 6) — estrutura de dados definida agora,
// lógica de auto-deleção e compactação implementada na Fase 6 (spec 0001 RNF4)
model OrderFile {
  id        String   @id @default(uuid())
  orderId   String
  name      String
  path      String
  // Tamanho em bytes
  size      Int
  mimeType  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order Order @relation(fields: [orderId], references: [id])

  @@index([orderId])
  @@map("order_files")
}
