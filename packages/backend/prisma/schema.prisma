// Gráfica Manager — Prisma Schema
// Banco: MySQL 8+
// IDs: UUID (sem auto-increment em entidades de domínio — CLAUDE.md seção 9)
// Tokens de e-commerce gravados encriptados — ADR 0001
// Schema atualizado para alinhar com specs 0006–0016 (2026-04-27)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum OrderStatus {
  draft           // Pedido em rascunho, não confirmado
  scheduled       // Pedido agendado para produção
  in_production   // Pedido em produção
  completed       // Produção concluída, aguardando envio
  shipping        // Pedido enviado (read-only)
  cancelled       // Pedido cancelado (terminal, sem transição)
}

enum PrintQuality {
  DRAFT
  NORMAL
  HIGH
}

enum ColorProfile {
  CMYK
  RGB
  GRAYSCALE
}

enum StoreSource {
  SHOPEE
  MERCADO_LIVRE
  MANUAL
}

enum WebhookStatus {
  pending         // Aguardando processamento
  processed       // Processado com sucesso
  error           // Erro no processamento
  discarded       // Descartado (duplicata, inválido)
  failed          // Falha permanente após retries
}

// ─── Entidades ────────────────────────────────────────────────────────────────

model Printer {
  id        String   @id @default(uuid())
  name      String
  model     String?
  // Identificador da impressora no sistema operacional
  systemId  String   @unique
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  printJobs PrintJob[]

  @@map("printers")
}

model PaperType {
  id           String    @id @default(uuid())
  name         String    // ex: "Sulfite A4", "Couchê 150g", etc.
  gsm          Int?      // Gramatura em g/m²
  size         String?   // ex: "A4", "A3"
  color        String?   // ex: "Branco", "Amarelo"
  active       Boolean   @default(true)
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime? // Soft-delete (spec 0022)

  printPresets PrintPreset[]
  printJobs    PrintJob[]
  priceEntries PriceTableEntry[]

  @@index([deletedAt])
  @@map("paper_types")
}

model PrintPreset {
  id           String       @id @default(uuid())
  name         String
  description  String?      @db.Text
  quality      PrintQuality
  colorProfile ColorProfile
  colors       String?      // "P&B" ou "colorido" (spec 0022)
  finish       String?      // "nenhum", "laminação", "encadernação" (spec 0022)
  paperTypeId  String?
  paperType    String?      // Fallback se paperTypeId não existir
  active       Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  deletedAt    DateTime?    // Soft-delete (spec 0022)

  paper     PaperType? @relation(fields: [paperTypeId], references: [id])
  printJobs PrintJob[]

  @@index([paperTypeId])
  @@index([deletedAt])
  @@map("print_presets")
}

model PriceTableEntry {
  id              String   @id @default(uuid())
  name            String?
  description     String?  @db.Text
  friendlyCode    String?  @unique
  paperTypeId     String
  quality         String   // "rascunho", "padrão", "premium"
  colors          String   // "P&B", "colorido"
  unitPrice       Decimal  @db.Decimal(12, 4)
  validUntil      DateTime?
  active          Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  paper  PaperType @relation(fields: [paperTypeId], references: [id])
  orders Order[]

  @@index([paperTypeId])
  @@map("price_table_entries")
}

model WebhookEvent {
  id              String         @id @default(uuid())
  source          String         // "shopee", "mercado_livre", etc.
  externalId      String         // shopee_order_id, order_id, etc. — deduplication key
  status          WebhookStatus  @default(pending)
  payload         Json           // Payload original do webhook (imutável para auditoria)
  mappingWarnings String?        @db.Text // JSON com avisos de mapeamento
  attempt         Int            @default(0) // Número de tentativa
  lastError       String?        @db.Text
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt

  orderId String?
  order   Order?  @relation(fields: [orderId], references: [id])

  @@unique([source, externalId])
  @@index([status])
  @@index([createdAt])
  @@map("webhook_events")
}

model Store {
  id             String      @id @default(uuid())
  name           String
  source         StoreSource
  // Valores gravados encriptados via AES-256-GCM (ADR 0001)
  accessToken    String      @db.Text
  refreshToken   String?     @db.Text
  externalShopId String?
  isActive       Boolean     @default(true)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  customers Customer[]
  orders    Order[]

  @@map("stores")
}

model Customer {
  id         String    @id @default(uuid())
  name       String
  email      String?   @unique // Spec 0009 RNF1
  phone      String?
  address    String?   @db.Text
  city       String?
  state      String?
  zipCode    String?
  notes      String?   @db.Text
  // ID do cliente na plataforma de e-commerce de origem
  externalId String?
  storeId    String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  // Soft-delete — queries de listagem filtram deletedAt: null (spec 0001 RNF3)
  deletedAt  DateTime?

  store            Store?            @relation(fields: [storeId], references: [id])
  orders           Order[]

  @@index([externalId])
  @@index([storeId])
  @@index([deletedAt])
  @@map("customers")
}

model Order {
  id                  String      @id @default(uuid())
  orderNumber         String      @unique // ex: "ORD-001", "ORD-SHOPEE-12345"
  status              OrderStatus @default(draft)
  description         String      @db.Text
  quantity            Int         @default(1)
  // Produto da tabela de preços selecionado no pedido manual
  priceTableEntryId   String?
  dueDate             DateTime?
  // ID do pedido na plataforma de e-commerce de origem
  externalOrderId     String?
  // Para Shopee: shopee_order_id (deduplication key)
  shopeeOrderId       String?     @unique
  shopeeShopId        String?
  // Valor de venda: calculado automaticamente (quantidade × preço unitário do produto)
  salePrice           Decimal     @db.Decimal(12, 4)
  notes               String?     @db.Text
  position            Int         @default(0)
  customerId          String?
  storeId             String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  // Soft-delete — queries de listagem filtram deletedAt: null (spec 0001 RNF3)
  deletedAt           DateTime?

  customer          Customer?          @relation(fields: [customerId], references: [id])
  store             Store?             @relation(fields: [storeId], references: [id])
  priceTableEntry   PriceTableEntry?   @relation(fields: [priceTableEntryId], references: [id])
  printJobs         PrintJob[]
  attachments       OrderAttachment[]
  statusHistory     OrderStatusHistory[]
  webhookEvents     WebhookEvent[]
  notifications     Notification[]

  @@index([status])
  @@index([customerId])
  @@index([storeId])
  @@index([priceTableEntryId])
  @@index([externalOrderId])
  @@index([shopeeOrderId])
  @@index([deletedAt])
  @@index([createdAt])
  @@map("orders")
}

model OrderStatusHistory {
  id        String   @id @default(uuid())
  orderId   String
  fromStatus String?
  toStatus   String
  reason     String?  @db.Text // ex: "Cancelado via Shopee", "Mudança manual"
  createdAt DateTime @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@map("order_status_history")
}

model PrintJob {
  id                 String       @id @default(uuid())
  orderId            String?
  printerId          String
  presetId           String?
  documentName       String?
  quality            PrintQuality
  colorProfile       ColorProfile
  paperTypeId        String?
  paperType          String? // Fallback se paperTypeId não existir
  // Gramatura em g/m²
  paperWeight        Int
  pagesBlackAndWhite Int          @default(0)
  pagesColor         Int          @default(0)
  // Custo CONGELADO do job no momento do registro (imutável, snapshot da tabela de preços)
  registeredCost     Decimal      @db.Decimal(12, 4)
  status             String       @default("success") // "success", "error", "cancelled"
  errorMessage       String?      @db.Text
  printedAt          DateTime     @default(now())
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt

  order   Order?     @relation(fields: [orderId], references: [id])
  printer Printer    @relation(fields: [printerId], references: [id])
  preset  PrintPreset? @relation(fields: [presetId], references: [id])
  paper   PaperType? @relation(fields: [paperTypeId], references: [id])

  @@index([printerId])
  @@index([orderId])
  @@index([createdAt])
  @@map("print_jobs")
}

// Módulo de Arquivo (Fase 6) — estrutura de dados definida agora,
// lógica de auto-deleção e compactação implementada na Fase 6 (spec 0001 RNF4)
model OrderAttachment {
  id               String    @id @default(uuid())
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  filename         String    // Nome único no disco (ex: uuid.pdf)
  originalFilename String    // Nome original enviado pelo usuário
  filepath         String    @unique // Caminho relativo no disco
  size             Int       // Tamanho em bytes
  mimeType         String
  uploadedAt       DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime? // Soft-delete (spec 0026)

  @@index([orderId])
  @@index([deletedAt])
  @@map("order_attachments")
}

model SystemSettings {
  id                 String   @id @default(uuid())
  name               String
  cnpj               String
  phone              String
  email              String
  website            String?
  address_street     String
  address_number     String
  address_complement String?
  address_city       String
  address_state      String
  address_zip        String
  logoPath           String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("system_settings")
}

model Notification {
  id          String   @id @default(uuid())
  title       String
  description String   @db.Text
  type        String   // 'webhook_failed' | 'order_deadline' | 'printer_offline' | 'shopee_sync_failed' | 'disk_full'
  category    String   // 'critical' | 'warning' | 'info'
  read        Boolean  @default(false)
  dismissedAt DateTime?

  // Links opcionais para contexto
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id])
  webhookId   String?

  actionUrl   String?  // ex: '/shopee' ou '/orders/ORD-001'
  actionLabel String?  // ex: 'Reprocessar' ou 'Ver Pedido'

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([read])
  @@index([dismissedAt])
  @@index([createdAt])
  @@map("notifications")
}
