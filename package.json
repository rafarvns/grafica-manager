{
  "name": "grafica-manager",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20",
    "pnpm": ">=9"
  },
  "scripts": {
    "dev": "pnpm --filter @grafica/backend dev & pnpm --filter @grafica/frontend dev",
    "dev:backend": "pnpm --filter @grafica/backend dev",
    "dev:frontend": "pnpm --filter @grafica/frontend dev",
    "dev:desktop": "concurrently -n \"Vite,Watch,App\" -c \"blue,yellow,green\" \"pnpm dev:frontend\" \"pnpm --filter @grafica/frontend electron:watch\" \"wait-on http://localhost:5173 && pnpm --filter @grafica/frontend electron:dev\"",
    "build": "pnpm --filter @grafica/shared build && pnpm --filter @grafica/backend build && pnpm --filter @grafica/frontend build",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "pnpm -r --filter=./packages/** run test:unit",
    "test:integration": "pnpm --filter @grafica/backend test:integration",
    "test:e2e": "pnpm --filter @grafica/frontend test:e2e",
    "lint": "pnpm -r run lint",
    "typecheck": "pnpm -r run typecheck"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "electron",
      "esbuild",
      "prisma"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "concurrently": "^9.2.1",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "wait-on": "^9.0.5"
  }
}
