API_TOKEN=

# Integração Shopee
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_SHOP_ID=
SHOPEE_ACCESS_TOKEN=

# Integração Mercado Livre
ML_APP_ID=
ML_CLIENT_SECRET=
ML_ACCESS_TOKEN=
ML_REFRESH_TOKEN=

# Segurança
WEBHOOK_SECRET=
# Gerar com: openssl rand -hex 32
ENCRYPTION_KEY=
